# ⚠️  SECURITY WARNING: This file contains default values for development only.
# ⚠️  NEVER commit your .env file to version control!
# ⚠️  ALWAYS generate strong passwords for production deployments.

# ============================================================================
# DATABASE CREDENTIALS
# ============================================================================
# CHANGE THESE IN PRODUCTION! Generate strong passwords:
# Linux/Mac: openssl rand -base64 32
# Windows: [Convert]::ToBase64String([System.Random]::new().NextBytes(32))
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_to_strong_password_$(date +%s)
POSTGRES_DB=erp_db

# ============================================================================
# MESSAGE QUEUE
# ============================================================================
KAFKA_BROKERS=kafka:9092

# ============================================================================
# CACHE LAYER
# ============================================================================
# CHANGE THIS IN PRODUCTION!
REDIS_PASSWORD=change_me_to_strong_password_$(date +%s)

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# CRITICAL: Generate a strong random secret for production!
# Generate with: openssl rand -hex 32
# DO NOT use this default in production!
JWT_SECRET=change_me_to_strong_jwt_secret_minimum_32_chars_required

# ============================================================================
# INITIAL ADMIN USER (Optional - used during seeding)
# ============================================================================
# These are used only for initial database seeding
# CHANGE THESE IMMEDIATELY after first login in production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately_after_first_login
ADMIN_EMAIL=admin@erp.local

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=info

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Generate strong credentials (see scripts/generate-secrets.sh)
# 3. Update all CHANGE_ME values with strong passwords
# 4. NEVER commit .env to git (it's in .gitignore)
# 5. For production, use a secrets manager (Vault, AWS Secrets Manager, etc.)
# ============================================================================
