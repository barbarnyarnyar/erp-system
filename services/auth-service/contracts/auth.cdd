service Auth {
    entity User {
        id            uuid      @primary
        username      string    @unique
        email         string    @unique
        password_hash string
        first_name    string
        last_name     string
        is_active     boolean
        created_at    timestamp
        updated_at    timestamp
    }

    entity Session {
        id            uuid      @primary
        user_id       uuid      @reference(User.id)
        refresh_token string
        expires_at    timestamp
        created_at    timestamp
    }

    entity Role {
        id            uuid      @primary
        name          string    @unique
        description   string
        created_at    timestamp
        updated_at    timestamp
    }

    entity Permission {
        id            uuid      @primary
        code          string    @unique
        description   string
        created_at    timestamp
        updated_at    timestamp
    }

    entity UserRole {
        id            uuid      @primary
        user_id       uuid      @reference(User.id)
        role_id       uuid      @reference(Role.id)
    }

    entity UserStore {
        id            uuid      @primary
        user_id       uuid      @reference(User.id)
        store_id      uuid
        assigned_at   timestamp
    }

    entity RolePermission {
        id            uuid      @primary
        role_id       uuid      @reference(Role.id)
        permission_id uuid      @reference(Permission.id)
    }

    component IdentityService {
        description: "Manages authentication, RBAC, and store assignments"

        func authenticateUser(username: string, passwordHash: string): string {
            description: "Verifies credentials and returns a JWT token"
        }

        func createUser(user: User, initialStoreId: string, roleIds: list<string>): User {
            description: "create a user and establish initial store and role relations via junction tables"
        }

        func updateUser(userId: string, updatedFields: object): User {
            description: "update a user, preventing passwordHash updates"
        }

        func updateCredentials(userId: string, newPasswordHash: string): boolean {
            description: "securely update a user password"
        }

        func assignUserToStore(userId: string, storeId: string): void {
            description: "Links a user to a specific branch via UserStore junction"
        }

        func validatePermissions(userId: string, permission: string): boolean {
            description: "Checks if a user has the required permission across all assigned roles"
        }

        func deactivateUser(userId: string): void {
            description: "Set isActive to false for a user"
        }
    }
}
